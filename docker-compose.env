# ========================================
# CMS 系统环境配置文件 (使用前请将此文件放在docker-compose.yml同级目录下，并重命名为.env)
# 使用前请务必修改所有示例值，尤其是密码和密钥！
# ========================================

# ------------------------------
# MongoDB 配置
# ------------------------------
MONGO_USER=cms_admin
MONGO_PASSWORD=SummerFlowerPwd2026

# ------------------------------
# Redis 配置
# ------------------------------
REDIS_PASSWORD=SummerFlowerPwd2026

# ------------------------------
# MinIO 对象存储配置
# ------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=SummerFlowerPwd2026
MINIO_PUBLIC_HOST=http://example.com
MINIO_BUCKET=media

# ------------------------------
# CMS 应用核心配置
# ------------------------------
APP_PORT=3000
ADMIN_USER=admin
ADMIN_EMAIL=admin@cms.local
ADMIN_PWD=AdminPwd123456
# 服务器 IP，用于 HTTPS 自签证书 SAN
SERVER_IP=example.com

# ------------------------------
# JWT 认证配置
# ------------------------------
JWT_SECRET=iA9gO8oP0bO3eH8vU2wA0rZ1rM5rW2aY
JWT_REFRESH_SECRET=rO0rD0lI9gI7xF6iF4kY3nG3aM6eI7gR
JWT_ACCESS_EXPIRES_IN=2h       # 访问令牌有效期，默认 15m
JWT_REFRESH_EXPIRES_IN=7d      # 刷新令牌有效期，默认 7d

# ------------------------------
# 安全与加密配置
# ------------------------------
ENCRYPTION_KEY=rQ2jP4jM2qY2eE8uW8oC8oS2tP4uB6pV
LOGIN_LIMIT_SHORT_WINDOW_SECONDS=300
LOGIN_LIMIT_SHORT_MAX_ATTEMPTS=5
LOGIN_LIMIT_SHORT_LOCK_SECONDS=300
LOGIN_LIMIT_LONG_WINDOW_SECONDS=86400
LOGIN_LIMIT_LONG_MAX_ATTEMPTS=20
LOGIN_LIMIT_LONG_LOCK_SECONDS=3600

# ------------------------------
# 验证码配置（可选，有默认值）
# ------------------------------
# CAPTCHA_EXPIRE_SECONDS=300   # 验证码有效期（秒），默认 300
# CAPTCHA_WIDTH=150            # 验证码图片宽度（px），默认 150
# CAPTCHA_HEIGHT=47            # 验证码图片高度（px），默认 47
# CAPTCHA_SIZE=4               # 验证码字符数量，默认 4

# ------------------------------
# 邮件通知配置（用于验证码、演唱会提醒等）
# 以 QQ 邮箱为例：HOST=smtp.qq.com PORT=465 SECURE=true
# 以网易163为例：HOST=smtp.163.com PORT=465 SECURE=true
# 以 Gmail 为例：HOST=smtp.gmail.com PORT=587 SECURE=false（需开启两步验证后使用应用密码）
# ------------------------------
NOTIFY_EMAIL_HOST=smtp.qq.com    # SMTP 服务器地址
NOTIFY_EMAIL_PORT=465            # SMTP 端口（SSL/TLS 通常为 465，STARTTLS 通常为 587）
NOTIFY_EMAIL_SECURE=true         # 端口 465 填 true，端口 587 填 false
NOTIFY_EMAIL_USER=               # 请输入发件邮箱账号
NOTIFY_EMAIL_PWD=                # 请输入邮箱授权码（非登录密码）
